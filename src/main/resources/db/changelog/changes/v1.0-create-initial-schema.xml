    <!-- ================================================================ -->
    <!--  SCHÉMA INITIAL COMPLET — ugate-service                          -->
    <!--  Ce fichier est la source unique de vérité pour le schéma DB.    -->
    <!--  Il remplace toutes les migrations v1.1 à v1.11.                 -->
    <!--  Toutes les preConditions le rendent idempotent :                -->
    <!--  sans danger sur une BD existante (les changeSets déjà appliqués -->
    <!--  sont ignorés via MARK_RAN).                                     -->
    <!-- ================================================================ -->


    <!-- ================================================================ -->
    <!-- 1. EXTENSIONS & TYPES                                            -->
    <!-- ================================================================ -->

    <changeSet id="v1.0-enable-pgcrypto" author="ugate-service">
        <sql>CREATE EXTENSION IF NOT EXISTS "pgcrypto";</sql>
        <rollback><sql>DROP EXTENSION IF EXISTS pgcrypto;</sql></rollback>
    </changeSet>

    <changeSet id="v1.0-create-role-type-enum" author="ugate-service">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM pg_catalog.pg_type WHERE typname = 'role_type_enum'
            </sqlCheck>
        </preConditions>
        <sql>CREATE DOMAIN role_type_enum AS VARCHAR(255);</sql>
        <rollback><sql>DROP DOMAIN IF EXISTS role_type_enum;</sql></rollback>
    </changeSet>

    <changeSet id="v1.0-create-reaction-type-enum" author="ugate-service">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM pg_catalog.pg_type WHERE typname = 'reaction_type_enum'
            </sqlCheck>
        </preConditions>
        <sql>CREATE DOMAIN reaction_type_enum AS VARCHAR(255);</sql>
        <rollback><sql>DROP DOMAIN IF EXISTS reaction_type_enum;</sql></rollback>
    </changeSet>

    <changeSet id="v1.0-create-cast-role-type-enum" author="ugate-service">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM pg_catalog.pg_cast
                                         JOIN pg_catalog.pg_type src ON pg_cast.castsource = src.oid
                                         JOIN pg_catalog.pg_type tgt ON pg_cast.casttarget = tgt.oid
                WHERE src.typname = 'varchar' AND tgt.typname = 'role_type_enum'
            </sqlCheck>
        </preConditions>
        <sql>CREATE CAST (character varying AS role_type_enum) WITH INOUT AS IMPLICIT;</sql>
        <rollback>
            <sql>DROP CAST IF EXISTS (character varying AS role_type_enum);</sql>
        </rollback>
    </changeSet>


